# ─────────────────────────────────────────────────────────
# ChargeClarity — Environment Variables
# ─────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your keys
# 3. NEVER commit .env to GitHub (it's in .gitignore)
# ─────────────────────────────────────────────────────────

# GROQ API KEY (Free LLM - Llama 3)
# Get it at: https://console.groq.com  → Create API Key
GROQ_API_KEY=your_groq_api_key_here

# Embedding model (no key needed — runs locally for free!)
# We use: sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM model via Groq (free tier)
LLM_MODEL=llama3-8b-8192
